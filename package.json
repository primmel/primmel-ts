{
  "name": "primmel-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "18.18",
    "gts": "^3.1.0",
    "tsx": "^4.23.0",
    "typescript": "^4.0.3"
  },
  "scripts": {
    "lint": "gts lint",
    "lint-clean": "gts clean",
    "lint-fix": "gts fix",
    "compile": "tsc",
    "test": "yarn workspace @primmel/primmel run test",
    "build": "yarn workspace @primmel/primmel run build",
    "prepare": "yarn run compile",
    "pretest": "yarn run compile",
    "posttest": "yarn run lint"
  },
  "description": "Primmel monorepo — TypeScript tools for the Primmel modelling language (formerly MMEL)",
  "repository": "https://github.com/primmel/primmel-ts",
  "homepage": "https://github.com/primmel/primmel-ts",
  "bugs": {
    "url": "https://github.com/primmel/primmel/issues"
  },
  "resolutions": {
    "ansi-regex": "^5.0.1",
    "brace-expansion": "^1.1.12",
    "cross-spawn": "^7.0.6",
    "got": "^11.8.5",
    "http-cache-semantics": "^4.1.1",
    "micromatch": "^4.0.8",
    "semver": "^7.5.4",
    "tmp": "^0.2.3",
    "word-wrap": "^1.2.5"
  }
}
